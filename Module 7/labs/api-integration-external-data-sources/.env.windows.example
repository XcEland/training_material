# SQL Server connection for Windows
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=localhost
DB_NAME=TrainingDB
DB_USER=
DB_PASSWORD=
DB_TRUSTED=yes

# Optional API authentication example.
EXTERNAL_API_KEY=
