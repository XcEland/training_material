# SQL Server connection for Windows
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=localhost
DB_NAME=TrainingDB
DB_USER=
DB_PASSWORD=
DB_TRUSTED=yes

# Optional API authentication example.
EXTERNAL_API_KEY=
EXTERNAL_API_USER_AGENT=Trainingcred-Module7-Lab/1.0

# Rate limiting
API_MIN_SECONDS_BETWEEN_CALLS=1.0

# Reference endpoints used by the teaching scripts
IMF_DATAMAPPER_BASE_URL=https://www.imf.org/external/datamapper/api
BIS_CBPOL_API_URL=https://stats.bis.org/api/v1/data/WS_CBPOL/all/all
BIS_CBPOL_BULK_GENERIC_ZIP=https://data.bis.org/static/bulk/WS_CBPOL_sdmx-generic-2.1.zip
BIS_CBPOL_BULK_CSV_ZIP=https://data.bis.org/static/bulk/WS_CBPOL_csv_flat.zip
