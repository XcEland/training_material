<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ report_title }}</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.5; color: #111827;">
  <h1 style="font-size: 22px; margin-bottom: 4px;">{{ report_title }}</h1>
  <p style="margin-top: 0;"><strong>Report month:</strong> {{ report_month }}</p>

  <p>Hello {{ recipient_name }},</p>

  <p>
    The automated reporting workflow status is:
    <strong>{{ status }}</strong>.
  </p>

  <h2 style="font-size: 17px;">Summary</h2>
  <ul>
    {% for item in summary_items %}
    <li>{{ item }}</li>
    {% endfor %}
  </ul>

  <p>Regards,<br>Module 6 automated reporting lab</p>
</body>
</html>
