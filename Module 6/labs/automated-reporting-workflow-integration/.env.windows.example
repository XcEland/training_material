# SQL Server connection for Windows
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_SERVER=localhost
DB_NAME=TrainingDB
DB_USER=
DB_PASSWORD=
DB_TRUSTED=yes

# Reporting behavior
REPORT_ENV=development
REPORT_FROM_EMAIL=reports@centralbank.example
REPORT_REPLY_TO=supervision@centralbank.example
SEND_EMAILS=false

# WEO data behavior
# Leave WEO_DOWNLOAD_URL blank to reuse the Module 4 workbook.
WEO_LOCAL_WORKBOOK=../../../Module 4/labs/python-data-manipulation-database-connectivity/data/WEOApr2026all.xlsx
WEO_DOWNLOAD_URL=

# SMTP settings are only used when SEND_EMAILS=true
SMTP_HOST=smtp.example.org
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
